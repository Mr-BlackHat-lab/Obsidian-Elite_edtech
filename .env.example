# OpenRouter - required for question generation
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# MongoDB - connects to Docker container
MONGODB_URL=mongodb://mongo:27017/learnpulse

# Redis - connects to Docker container
REDIS_URL=redis://redis:6379/0

# Shared optional key (used by clients/features that call YouTube Data API)
YOUTUBE_API_KEY=
YOUTUBE_CAPTION_CACHE_SIZE=128

# Optional transcription settings
WHISPER_MODEL=base
WHISPER_ENABLED=false
WHISPER_YTDLP_FALLBACK=true
OPENAI_API_KEY=

# Free-tier cost control (recommended defaults)
FREE_TIER_MODE=true
MAX_CHUNKS_PER_VIDEO=1
MAX_QUESTIONS_PER_SESSION=5
CONCEPT_SIMILARITY_THRESHOLD=0.85
VIDEO_QUESTION_CACHE_TTL=86400
OPENROUTER_MAX_TRANSCRIPT_CHARS=900
OPENROUTER_MAX_OUTPUT_TOKENS=700
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=25
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=LearnPulse AI

# App config
APP_ENV=development
DEBUG=true

# JWT
JWT_SECRET=supersecretkey
JWT_ALGORITHM=HS256

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
