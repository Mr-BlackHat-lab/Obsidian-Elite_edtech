{
  "manifest_version": 3,
  "name": "LearnPulse AI",
  "version": "1.0.0",
  "description": "Active recall learning enforcement layer for any educational video.",
  "permissions": [
    "tabs",
    "storage",
    "tabCapture",
    "activeTab"
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://*.udemy.com/*",
    "*://*.coursera.org/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/watch*",
        "*://*.udemy.com/course/*",
        "*://*.coursera.org/learn/*"
      ],
      "js": ["dist/content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LearnPulse AI"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}