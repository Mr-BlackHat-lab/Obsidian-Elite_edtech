# Google Gemini - required for question generation only (NOT transcription)
GEMINI_API_KEY=AIzaSyDB_cC4PjA965CtuqhaHr03e9pWdFLvgcE
GEMINI_MODEL=gemini-2.0-flash

# MongoDB - connects to Docker container
MONGODB_URL=mongodb://mongo:27017/learnpulse

# Redis - connects to Docker container
REDIS_URL=redis://redis:6379/0

# Shared optional key (used by clients/features that call YouTube Data API)
YOUTUBE_API_KEY=AIzaSyBsP_FV2taF12XJEYWzRhRxBpX7ECIZhA0
YOUTUBE_CAPTION_CACHE_SIZE=128

# Local Whisper model for live audio transcription (base or tiny)
WHISPER_MODEL=base

# Free-tier cost control
FREE_TIER_MODE=true
MAX_CHUNKS_PER_VIDEO=1
MAX_QUESTIONS_PER_SESSION=5
CONCEPT_SIMILARITY_THRESHOLD=0.85
VIDEO_QUESTION_CACHE_TTL=86400
GEMINI_MAX_TRANSCRIPT_CHARS=900
GEMINI_MAX_OUTPUT_TOKENS=700
GEMINI_TEMPERATURE=0.2

# App config
APP_ENV=development
DEBUG=true

# CLI/backend connection
BACKEND_URL=http://localhost:8000
